  m_GameObject: {fileID: 164191466}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: ffaba787cd1654aa898df58b0313109a, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::TutorialManager
  gellyController: {fileID: 2098698659}
  focusController: {fileID: 1651605329}
  chatBubbleContainer: {fileID: 216441319}
  chatBubbleCurve:
    serializedVersion: 2
    m_Curve:
    - serializedVersion: 3
      time: 0
      value: 0
      inSlope: 0
      outSlope: 0
      tangentMode: 0
      weightedMode: 0
      inWeight: 0
      outWeight: 0
    - serializedVersion: 3
      time: 1
      value: 1
      inSlope: 0
      outSlope: 0
      tangentMode: 0
      weightedMode: 0
      inWeight: 0
      outWeight: 0
    m_PreInfinity: 2
    m_PostInfinity: 2
    m_RotationOrder: 4
  defaultChatBubbleDuration: 0.5
  continueArrowIndicator: {fileID: 860262287}
  dialogueTextMesh: {fileID: 233669322}
  audioSource: {fileID: 19911373}
  voiceAudioSource: {fileID: 20861824}
  textSpeed: 0.03
  characterSoundInterval: 2
  randomizeVoicePitch: 1
  tutorialSteps:
  - dialogueText: "\xA1Hola, hola! Soy Gelly, tu nueva gelatina favorita y experta
      en circuitos. \xA1Qu\xE9 bendici\xF3n que llegaste! "
    delayBeforeStep: 0
    delayBeforeText: 1.5
    stepAudio: {fileID: 8300000, guid: eec23be66695b4dbc89e84ebf9f5cc08, type: 3}
    voiceSound: {fileID: 8300000, guid: eb0687cf0d59a4e72ae69014d69e0192, type: 3}
    moveCharacter: 1
    targetCharacterPosition: {x: -9.93, y: 5.95}
    characterTargetScale: 1.2
    gellyFollowsChatPace: 0
    moveChatBubble: 1
    targetChatAnchoredPosition: {x: -12.02, y: 130}
    chatBubbleDuration: 0
    delayBeforeChatBubble: 0.5
    useFocusUI: 0
    targetUIElement: {fileID: 0}
    focusCornerRadius: 0
    onStepStartCustomAction:
      m_PersistentCalls:
        m_Calls: []
  - dialogueText: "Mi taller de reparaciones est\xE1 un poco... colapsado, y necesito
      que me eches una mano para revivir estos aparatos. \xA1Prep\xE1rate, porque
      hoy nos toca chambear duro! "
    delayBeforeStep: 0
    delayBeforeText: 0
    stepAudio: {fileID: 8300000, guid: eec23be66695b4dbc89e84ebf9f5cc08, type: 3}
    voiceSound: {fileID: 8300000, guid: eb0687cf0d59a4e72ae69014d69e0192, type: 3}
    moveCharacter: 0
    targetCharacterPosition: {x: 0, y: 0}
    characterTargetScale: 0
    gellyFollowsChatPace: 0
    moveChatBubble: 0
    targetChatAnchoredPosition: {x: 0, y: 0}
    chatBubbleDuration: 0
    delayBeforeChatBubble: 0
    useFocusUI: 0
    targetUIElement: {fileID: 0}
    focusCornerRadius: 0
    onStepStartCustomAction:
      m_PersistentCalls:
        m_Calls:
        - m_Target: {fileID: 977882474}
          m_TargetAssemblyTypeName: LEExtraBehaviourSteps, Assembly-CSharp
          m_MethodName: Step2ExtraB
          m_Mode: 1
          m_Arguments:
            m_ObjectArgument: {fileID: 0}
            m_ObjectArgumentAssemblyTypeName: UnityEngine.Object, UnityEngine
            m_IntArgument: 0
            m_FloatArgument: 0
            m_StringArgument: 
            m_BoolArgument: 0
          m_CallState: 2
  - dialogueText: "\xA1Mira all\xE1! Esta es la cinta transportadora. Por aqu\xED
      van a ir llegando todos los electrodom\xE9sticos que piden a gritos un milagro.
      No los dejes acumulase, \xA1hay que mantener el flujo constante y con buena
      vibra! "
    delayBeforeStep: 0
    delayBeforeText: 0
    stepAudio: {fileID: 8300000, guid: eec23be66695b4dbc89e84ebf9f5cc08, type: 3}
    voiceSound: {fileID: 8300000, guid: eb0687cf0d59a4e72ae69014d69e0192, type: 3}
    moveCharacter: 0
    targetCharacterPosition: {x: 0, y: 0}
    characterTargetScale: 0
    gellyFollowsChatPace: 0
    moveChatBubble: 0
    targetChatAnchoredPosition: {x: 0, y: 0}
    chatBubbleDuration: 0
    delayBeforeChatBubble: 0
    useFocusUI: 1
    targetUIElement: {fileID: 809819024}
    focusCornerRadius: 0.01
    onStepStartCustomAction:
      m_PersistentCalls:
        m_Calls: []
  - dialogueText: "El proceso es superorg\xE1nico: cuando veas un aparato en la cinta,
      solo arr\xE1stralo a la mesa de trabajo. "
    delayBeforeStep: 0
    delayBeforeText: 0
    stepAudio: {fileID: 8300000, guid: eec23be66695b4dbc89e84ebf9f5cc08, type: 3}
    voiceSound: {fileID: 8300000, guid: eb0687cf0d59a4e72ae69014d69e0192, type: 3}
    moveCharacter: 0
    targetCharacterPosition: {x: 0, y: 0}
    characterTargetScale: 0
    gellyFollowsChatPace: 0
    moveChatBubble: 0
    targetChatAnchoredPosition: {x: 0, y: 0}
    chatBubbleDuration: 0
    delayBeforeChatBubble: 0
    useFocusUI: 1
    targetUIElement: {fileID: 759911199}
    focusCornerRadius: 0.01
    onStepStartCustomAction:
      m_PersistentCalls:
        m_Calls: []
  - dialogueText: "Eso s\xED, el tiempo corre y no podemos quedarnos congelados (o
      derretidos, en mi caso) "
    delayBeforeStep: 0
    delayBeforeText: 0
    stepAudio: {fileID: 8300000, guid: eec23be66695b4dbc89e84ebf9f5cc08, type: 3}
    voiceSound: {fileID: 8300000, guid: eb0687cf0d59a4e72ae69014d69e0192, type: 3}
    moveCharacter: 1
    targetCharacterPosition: {x: -9.92, y: 0.94}
    characterTargetScale: 1.2
    gellyFollowsChatPace: 1
    moveChatBubble: 1
    targetChatAnchoredPosition: {x: -12.02, y: -98}
    chatBubbleDuration: 0
    delayBeforeChatBubble: 0
    useFocusUI: 1
    targetUIElement: {fileID: 1850319249}
    focusCornerRadius: 0.01
    onStepStartCustomAction:
      m_PersistentCalls:
        m_Calls: []
  - dialogueText: "Si el reloj se pone tenso y sientes que un aparato te va a arruinar
      la racha, no te preocupes, no es un evento can\xF3nico. \xA1Puedes mandarlo
      directo a la caja de descartes! A veces toca decir \"siguiente\" y avanzar
      de chill. "
    delayBeforeStep: 0
    delayBeforeText: 0
    stepAudio: {fileID: 8300000, guid: eec23be66695b4dbc89e84ebf9f5cc08, type: 3}
    voiceSound: {fileID: 8300000, guid: eb0687cf0d59a4e72ae69014d69e0192, type: 3}
    moveCharacter: 1
    targetCharacterPosition: {x: -9.93, y: 5.95}
    characterTargetScale: 1.2
    gellyFollowsChatPace: 1
    moveChatBubble: 1
    targetChatAnchoredPosition: {x: -12.02, y: 130}
    chatBubbleDuration: 0
    delayBeforeChatBubble: 0
    useFocusUI: 1
    targetUIElement: {fileID: 2098283043}
    focusCornerRadius: 0.01
    onStepStartCustomAction:
      m_PersistentCalls:
        m_Calls: []
  - dialogueText: "Por aqu\xED arriba tienes tu conteo. Te muestra exactamente cu\xE1ntos
      electrodom\xE9sticos has reparado y cu\xE1ntos te faltan para terminar el turno."
    delayBeforeStep: 0
    delayBeforeText: 0
    stepAudio: {fileID: 8300000, guid: eec23be66695b4dbc89e84ebf9f5cc08, type: 3}
    voiceSound: {fileID: 8300000, guid: eb0687cf0d59a4e72ae69014d69e0192, type: 3}
    moveCharacter: 1
    targetCharacterPosition: {x: -9.92, y: 0.94}
    characterTargetScale: 1.2
    gellyFollowsChatPace: 1
    moveChatBubble: 1
    targetChatAnchoredPosition: {x: -12.02, y: -98}
    chatBubbleDuration: 0
    delayBeforeChatBubble: 0
    useFocusUI: 1
    targetUIElement: {fileID: 1975291487}
    focusCornerRadius: 0.01
    onStepStartCustomAction:
      m_PersistentCalls:
        m_Calls: []
  - dialogueText: "Para cantar victoria hoy solo necesitas reparar con \xE9xito al
      menos un electrodom\xE9stico. "
    delayBeforeStep: 0
    delayBeforeText: 0
    stepAudio: {fileID: 8300000, guid: eec23be66695b4dbc89e84ebf9f5cc08, type: 3}
    voiceSound: {fileID: 8300000, guid: eb0687cf0d59a4e72ae69014d69e0192, type: 3}
    moveCharacter: 1
    targetCharacterPosition: {x: -9.93, y: 5.95}
    characterTargetScale: 1.2
    gellyFollowsChatPace: 1
    moveChatBubble: 1
    targetChatAnchoredPosition: {x: -12.02, y: 130}
    chatBubbleDuration: 0
    delayBeforeChatBubble: 0
    useFocusUI: 1
    targetUIElement: {fileID: 0}
    focusCornerRadius: 0.01
    onStepStartCustomAction:
      m_PersistentCalls:
        m_Calls: []
  - dialogueText: "\xA1Pero no te me estanques! Por cada aparato que dejes impecable
      y como nuevo, \xA1te vas a llevar 50 monedas directitas al bolsillo!"
    delayBeforeStep: 0
    delayBeforeText: 0
    stepAudio: {fileID: 8300000, guid: eec23be66695b4dbc89e84ebf9f5cc08, type: 3}
    voiceSound: {fileID: 8300000, guid: eb0687cf0d59a4e72ae69014d69e0192, type: 3}
    moveCharacter: 0
    targetCharacterPosition: {x: -9.93, y: 5.95}
    characterTargetScale: 1.2
    gellyFollowsChatPace: 0
    moveChatBubble: 0
    targetChatAnchoredPosition: {x: -12.02, y: 130}
    chatBubbleDuration: 0
    delayBeforeChatBubble: 0
    useFocusUI: 0
    targetUIElement: {fileID: 0}
    focusCornerRadius: 0.01
    onStepStartCustomAction:
      m_PersistentCalls:
        m_Calls: []
  - dialogueText: "Muy bien, ya te la sabes. El dise\xF1o de este taller es de alto
      rendimiento, \xA1as\xED que demuestra de lo que eres capaz! \xBFListo para
      iniciar la simulaci\xF3n? \xA1Dale jugar y que empiecen los chispazos!"
    delayBeforeStep: 0
    delayBeforeText: 0
    stepAudio: {fileID: 8300000, guid: eec23be66695b4dbc89e84ebf9f5cc08, type: 3}
