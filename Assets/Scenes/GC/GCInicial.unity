--- !u!114 &1839189027
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 1839189023}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 4e17151a4464a4f088b2a7fcafa8b679, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::SistemaPreguntas
  panelGenerador: {fileID: 1257121604}
  textoPregunta: {fileID: 234080247}
  botonesOpciones:
  - {fileID: 119966174}
  - {fileID: 283810414}
  - {fileID: 502607080}
  - {fileID: 1869607071}
  textosOpciones:
  - {fileID: 864026948}
  - {fileID: 9525709}
  - {fileID: 1343121655}
  - {fileID: 310505232}
  btnSiguiente: {fileID: 2007058015}
  btnCerrarGenerador: {fileID: 202330530}
  spriteBotonNormal: {fileID: 7554801569241005110, guid: 9384d8ad21bc7433baf45af17cb43051, type: 3}
  spriteBotonCorrecto: {fileID: 9213332613473862990, guid: 9384d8ad21bc7433baf45af17cb43051, type: 3}
  spriteBotonIncorrecto: {fileID: -6411227630628679668, guid: 9384d8ad21bc7433baf45af17cb43051, type: 3}
  urlAPI: http://localhost:8001/preguntas
  usarBD: 1
  preguntas:
  - pregunta: "\xBFQu\xE9 es un prompt?"
    opciones:
    - Un error del sistema
    - "Una instrucci\xF3n o entrada que se le da a una IA"
    - "Un archivo de programaci\xF3n"
    - "Una respuesta autom\xE1tica"
    respuestaCorrecta: 1
    explicacion: "Un prompt es el mensaje, pregunta o instrucci\xF3n que se escribe
      para que una IA genere una respuesta."
  - pregunta: "\xBFCu\xE1l es el objetivo principal de la ingenier\xEDa de prompts?"
    opciones:
    - "Hacer preguntas m\xE1s largas"
    - Mejorar la calidad de las respuestas de la IA
    - "Evitar usar tecnolog\xEDa"
    - Cambiar el idioma del sistema
    respuestaCorrecta: 1
    explicacion: "La ingenier\xEDa de prompts busca formular mejores instrucciones
      para obtener respuestas m\xE1s \xFAtiles, precisas y adaptadas a lo que se
      necesita."
  - pregunta: "\xBFQu\xE9 caracter\xEDstica debe tener un buen prompt?"
    opciones:
    - "Ser claro y espec\xEDfico "
    - Ser ambiguo
    - "Ser lo m\xE1s corto posible siempre"
    - No incluir contexto
    respuestaCorrecta: 0
    explicacion: "Un prompt claro y espec\xEDfico reduce confusiones y ayuda a la
      IA a entender exactamente qu\xE9 debe responder."
  - pregunta: "\xBFQu\xE9 suele pasar si un prompt es muy general?"
    opciones:
    - "La IA responde con mayor precisi\xF3n"
    - La IA puede dar una respuesta vaga o incompleta
    - La IA deja de funcionar
    - "La IA genera im\xE1genes autom\xE1ticamente"
    respuestaCorrecta: 1
    explicacion: "Cuando el prompt no da detalles suficientes, la IA tiene que asumir
      informaci\xF3n y puede responder de forma poco precisa."
  - pregunta: "\xBFCu\xE1l de estos prompts es mejor?"
    opciones:
    - "\u201CExpl\xEDcame algo\u201D"
    - "\u201CHazme una tarea\u201D"
    - "\u201CExplica qu\xE9 es la ingenier\xEDa de prompts con ejemplos simples para
      estudiantes\u201D"
    - "\u201CDime todo\u201D"
    respuestaCorrecta: 2
    explicacion: "La opci\xF3n correcta indica tema, tipo de explicaci\xF3n y p\xFAblico
      objetivo. Eso permite una respuesta m\xE1s adecuada."
  - pregunta: "\xBFPor qu\xE9 es importante indicar el objetivo del prompt?"
    opciones:
    - Porque ayuda a orientar la respuesta
    - "Porque hace que la respuesta sea m\xE1s corta siempre"
    - "Porque evita que la IA use informaci\xF3n"
    - Porque elimina la necesidad de contexto
    respuestaCorrecta: 0
    explicacion: "El objetivo le dice a la IA para qu\xE9 se usar\xE1 la respuesta,
      lo que mejora el enfoque y la utilidad del resultado."
  - pregunta: "\xBFQu\xE9 significa ser espec\xEDfico en un prompt?"
    opciones:
    - Usar palabras complicadas
    - 'Dar detalles claros sobre lo que se necesita '
    - "Escribir sin signos de puntuaci\xF3n"
    - 'Pedir muchas cosas sin orden '
    respuestaCorrecta: 1
    explicacion: "Ser espec\xEDfico significa explicar con claridad qu\xE9 se quiere,
      c\xF3mo se quiere y para qu\xE9 se necesita."
  - pregunta: "\xBFQu\xE9 elemento mejora mucho la calidad de un prompt?"
    opciones:
    - Contexto
    - "Ambig\xFCedad"
    - Errores intencionales
    - Falta de instrucciones
    respuestaCorrecta: 0
    explicacion: "El contexto ayuda a la IA a comprender la situaci\xF3n, el prop\xF3sito
      y el tipo de respuesta esperada."
  - pregunta: "\xBFCu\xE1l es una mala pr\xE1ctica al escribir prompts?"
    opciones:
    - Dar instrucciones claras
    - "Pedir un formato espec\xEDfico"
    - "Usar frases vagas como \u201Chazlo bien\u201D sin explicar qu\xE9 significa"
    - Dar ejemplos
    respuestaCorrecta: 2
    explicacion: "Frases como \u201Chazlo bien\u201D son ambiguas. Es mejor definir
      qu\xE9 significa \u201Cbien\u201D: breve, formal, con ejemplos, paso a paso,
      etc."
  - pregunta: "\xBFQu\xE9 pregunta ayuda a mejorar un prompt antes de enviarlo?"
    opciones:
    - "\u201C\xBFLa IA sabe exactamente qu\xE9 quiero?\u201D "
    - "\u201C\xBFPuedo hacerlo m\xE1s confuso?\u201D"
    - "\u201C\xBFLe quit\xE9 todo el contexto?\u201D"
    - "\u201C\xBFEs imposible de entender?\u201D"
    respuestaCorrecta: 0
    explicacion: "Revisar si la instrucci\xF3n es clara permite detectar si falta
      informaci\xF3n antes de pedir la respuesta."
  - pregunta: "\xBFPara qu\xE9 sirve dar contexto en un prompt?"
    opciones:
    - Para confundir al modelo
    - "Para que la IA entienda mejor la situaci\xF3n"
    - "Para hacer m\xE1s lento el proceso"
    - Para eliminar la respuesta
    respuestaCorrecta: 1
    explicacion: "El contexto permite que la IA adapte la respuesta al caso espec\xEDfico,
      en lugar de responder de forma gen\xE9rica."
  - pregunta: "\xBFCu\xE1l de estos ejemplos incluye mejor contexto?"
    opciones:
